# ============================================================================
# INFINITY ADMIN IMPLEMENTATION RUNNER - ENVIRONMENT CONFIGURATION
# ============================================================================
# Production-Ready | Zero-Cost Optimized | 2060 Future-Proof
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.production
# 2. Fill in your API keys (all free tier providers)
# 3. Customize settings as needed
# 4. Never commit .env.production to version control
# ============================================================================

# ============================================================================
# AI PROVIDER API KEYS (Zero-Cost / Free Tier)
# ============================================================================

# HuggingFace (Free) - https://huggingface.co/settings/tokens
# Required for: Qwen models, Code generation
HF_TOKEN=

# Groq (Free 14,400 req/day) - https://console.groq.com/keys
# Required for: Fast inference, Llama models
GROQ_API_KEY=

# Google Gemini (Free) - https://aistudio.google.com/app/apikey
# Required for: Gemini models, Multimodal
GOOGLE_API_KEY=

# DeepSeek (Free credits) - https://platform.deepseek.com/
# Required for: DeepSeek Chat & Reasoner
DEEPSEEK_API_KEY=

# Cloudflare AI (Optional, Free) - https://dash.cloudflare.com/
CLOUDFLARE_AI_TOKEN=

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# API Token (CHANGE THIS!)
# Generate with: openssl rand -base64 32
API_TOKEN=

# JWT Configuration
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=*

# CORS Origins (comma-separated)
CORS_ORIGINS=*

# ============================================================================
# RATE LIMITING & PERFORMANCE
# ============================================================================

RATE_LIMIT=100
RATE_LIMIT_HOUR=1000
MAX_TOKENS=8192
MAX_REQUEST_SIZE=50000
REQUEST_TIMEOUT=120

# ============================================================================
# FEATURE FLAGS
# ============================================================================

SCOUT_ENABLED=true
COGNITIVE_EXERCISES_ENABLED=true
STREAMING_ENABLED=true
WEBSOCKET_ENABLED=true
METRICS_ENABLED=true
CACHING_ENABLED=true

# ============================================================================
# COMPLIANCE & GOVERNANCE
# ============================================================================

GDPR_ENABLED=true
ISO27001_ENABLED=true
SOC2_ENABLED=true
HIPAA_ENABLED=false
DATA_RETENTION_DAYS=30
AUDIT_LOGGING=true

# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================

QWEN3_MAX_ENABLED=true
FREE_TIER_PRIORITY=true
MODEL_FALLBACK_ENABLED=true

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

LOG_LEVEL=INFO
STRUCTURED_LOGGING=true
TRACE_SAMPLING_RATE=0.1

# ============================================================================
# ENVIRONMENT
# ============================================================================

ENVIRONMENT=production
PORT=8000
WORKERS=4

# ============================================================================
# OPTIONAL: ADVANCED CONFIGURATIONS
# ============================================================================

# Custom Model Endpoints (if self-hosting)
# CUSTOM_MODEL_ENDPOINT=

# Database (if using PostgreSQL for audit logs)
# DATABASE_URL=postgresql://user:pass@localhost:5432/infinity_admin

# S3 Compatible Storage (for file uploads)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# Email (for notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# Sentry (error tracking)
# SENTRY_DSN=

# ============================================================================
# FUTURE-PROOFING (2060 Ready)
# ============================================================================

# Quantum-Resistant Crypto (preparation)
QUANTUM_RESISTANT_CRYPTO_ENABLED=false

# Distributed Tracing
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Advanced Observability
OPENTELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ============================================================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================================================

# For Railway.app
# RAILWAY_STATIC_URL=
# RAILWAY_PUBLIC_DOMAIN=

# For Render.com
# RENDER_EXTERNAL_URL=

# For Fly.io
# FLY_APP_NAME=
# FLY_REGION=

# For Cloud Run
# GOOGLE_CLOUD_PROJECT=
# CLOUD_RUN_SERVICE=

# ============================================================================
# NOTES
# ============================================================================
# - All AI providers listed offer free tiers suitable for production use
# - Redis can be self-hosted or use free tier from Upstash/Redis Labs
# - Generate secure tokens using: openssl rand -base64 32
# - For production: Set ENVIRONMENT=production
# - For development: Set ENVIRONMENT=development
# - Monitor costs even with free tiers to stay within limits
# - Review GDPR settings if serving EU users
# - Update DATA_RETENTION_DAYS based on compliance requirements
# ============================================================================
