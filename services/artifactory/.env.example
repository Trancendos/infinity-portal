# ============================================================
# Trancendos Artifactory — Environment Configuration
# Enhanced v2.0.0 — Multi-Protocol Registry + Intelligence Layer
# ============================================================

# --- Service ---
NODE_ENV=development
PORT=3041
LOG_LEVEL=info
SERVICE_NAME=artifactory
SERVICE_VERSION=2.0.0

# --- IAM / Auth ---
IAM_JWT_SECRET=your-jwt-secret-here
IAM_JWT_ALGORITHM=HS512
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=trancendos
KEYCLOAK_CLIENT_ID=artifactory
JWT_ISSUER=https://auth.trancendos.com/realms/trancendos

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://trancendos:trancendos@localhost:5432/artifactory

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Storage (Cloudflare R2 / S3-compatible) ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=trancendos-artifacts
R2_PUBLIC_URL=https://artifacts.trancendos.com

# --- Search (Meilisearch) ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-key

# --- Mesh ---
MESH_ROUTING_PROTOCOL=static_port
MESH_ADDRESS=localhost:3041
NEXUS_URL=http://localhost:3030
AGORA_URL=http://localhost:3040
OBSERVATORY_URL=http://localhost:3042
LIGHTHOUSE_URL=http://localhost:3043
TREASURY_URL=http://localhost:3044
ICEBOX_URL=http://localhost:3045
CORNELIUS_URL=http://localhost:3046

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- 2060 Compliance ---
TRANCENDOS_2060_COMPLIANCE=active
SMART_RESILIENCE_LAYER=enabled
