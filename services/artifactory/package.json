{
  "name": "@trancendos/artifactory",
  "version": "2.0.0",
  "description": "Trancendos Artifactory \u2014 Enterprise artifact registry, multi-protocol package management, and intelligent asset storage for the ecosystem mesh",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "audit:contamination": "node scripts/contamination-audit.js",
    "docker:build": "docker build -t trancendos/artifactory .",
    "docker:run": "docker run -p 3041:3041 trancendos/artifactory"
  },
  "keywords": [
    "trancendos",
    "docker-registry",
    "npm-registry",
    "helm-registry",
    "artifactory",
    "artifact-registry",
    "packages",
    "terraform-registry",
    "registry",
    "2060",
    "microservice",
    "mesh"
  ],
  "author": "Trancendos <admin@trancendos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trancendos/infinity-portal.git",
    "directory": "repos/artifactory"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.0",
    "semver": "^7.6.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "drizzle-orm": "^0.30.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "meilisearch": "^0.38.0",
    "morgan": "^1.10.0",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "postgres": "^3.4.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/uuid": "^9.0.7",
    "@types/semver": "^7.5.6",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/morgan": "^1.9.9",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
