# ============================================================
# Infinity Portal — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the .env file to version control.
# ============================================================

# ── Database ───────────────────────────────────────────────
POSTGRES_DB=infinity
POSTGRES_USER=infinity
POSTGRES_PASSWORD=          # REQUIRED: Strong password (min 32 chars)
DATABASE_URL=               # REQUIRED: postgresql+asyncpg://user:pass@host:5432/db

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────
SECRET_KEY=                 # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=             # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Application ───────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=warning
WORKERS=4

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=https://infinity-portal.pages.dev,https://infinity-portal.com

# ── Backend URLs ──────────────────────────────────────────
BACKEND_URL=https://api.infinity-portal.com
WS_URL=wss://api.infinity-portal.com/ws

# ── Frontend (Vite Build Args) ────────────────────────────
VITE_BACKEND_API_URL=https://api.infinity-portal.com
VITE_WS_URL=wss://api.infinity-portal.com/ws
VITE_APP_NAME=Infinity Portal
VITE_APP_VERSION=2.5.0

# ── Ports ─────────────────────────────────────────────────
DB_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Cloudflare ────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=       # REQUIRED: Cloudflare API token
CLOUDFLARE_ACCOUNT_ID=      # REQUIRED: Cloudflare account ID

# ── Monitoring (Optional) ─────────────────────────────────
SENTRY_DSN=                 # Optional: Sentry error tracking
AXIOM_TOKEN=                # Optional: Axiom log ingestion
UPTIME_WEBHOOK=             # Optional: Uptime monitoring webhook

# ── Email (Optional) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@infinity-portal.com

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_RPM=120          # Requests per minute per IP
RATE_LIMIT_BURST=20         # Burst allowance