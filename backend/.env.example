# ============================================================
# Infinity OS Backend Configuration
# Copy to .env and update values
# NEVER commit .env to version control
# ============================================================
#
# Quick start:
#   cp .env.example .env
#   docker compose up -d
#
# Full stack (with edge DB, S3, email):
#   docker compose --profile edge --profile tools up -d
#
# Run migrations:
#   docker compose --profile migrate up -d
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://infinity:your_password@localhost:5432/infinity_os
DB_PASSWORD=infinity_dev_2026

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=generate-a-64-char-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Storage (filesystem paths inside container) ---
FILE_STORAGE_ROOT=/data/files
GIT_STORAGE_ROOT=/data/repos
BUILD_OUTPUT_ROOT=/data/builds

# --- Redis (Valkey) ---
REDIS_URL=redis://localhost:6379/0

# ============================================================
# EDGE DATABASE (LibSQL / Turso)
# Used for read-heavy queries, offline-first sync, Hive Lane
# caching. Enable with: docker compose --profile edge up -d
# ============================================================
LIBSQL_URL=http://localhost:8080
LIBSQL_AUTH_TOKEN=infinity-edge-dev-token-2026
LIBSQL_SYNC_INTERVAL=30

# For production Turso cloud:
# LIBSQL_URL=libsql://your-db-name-your-org.turso.io
# LIBSQL_AUTH_TOKEN=your-turso-auth-token

# ============================================================
# S3 OBJECT STORAGE (MinIO in dev, any S3-compatible in prod)
# Enable with: docker compose --profile tools up -d
# ============================================================
S3_ENDPOINT_URL=http://localhost:9000
MINIO_ROOT_USER=infinity
MINIO_ROOT_PASSWORD=infinity_dev_2026
S3_BUCKET_FILES=infinity-files
S3_BUCKET_BUILDS=infinity-builds
S3_BUCKET_ARTIFACTS=infinity-artifacts

# For production (AWS S3, Cloudflare R2, etc.):
# S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ============================================================
# EMAIL (Mailpit in dev, real SMTP in prod)
# Enable Mailpit with: docker compose --profile tools up -d
# Mailpit web UI: http://localhost:8025
# ============================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@infinity-os.dev

# For production:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# ============================================================
# GITHUB INTEGRATION (for repo sync)
# ============================================================
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=Trancendos

# ============================================================
# LLM PROVIDERS
# Configure at least one provider. The system uses automatic
# fallback: groq → openai → anthropic → huggingface → local → stub
#
# Set LLM_PROVIDER to force a specific provider (optional).
# If unset, the first provider with a valid API key is used.
# ============================================================

# Preferred provider (optional): openai, groq, anthropic, huggingface, local
LLM_PROVIDER=

# Groq — Free tier: 30 req/min, 14,400 req/day
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — Pay-per-use
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — Pay-per-use
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# HuggingFace — Free inference API (rate limited)
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=

# Local LLM (Ollama) — Free, runs on your hardware
# Install: https://ollama.ai → ollama pull qwen2.5-coder:32b
LOCAL_LLM_URL=http://localhost:11434/v1

# ============================================================
# KERNEL EVENT BUS
# Async pub/sub backbone connecting all Three-Lane Mesh services
# ============================================================
EVENT_BUS_MAX_HISTORY=10000
EVENT_BUS_MAX_DEAD_LETTER=1000
EVENT_BUS_RETRY_LIMIT=3

# ============================================================
# C2PA CONTENT PROVENANCE (EU AI Act Compliance)
# ============================================================

# Enable C2PA cryptographic signing for AI-generated content
C2PA_ENABLED=false

# Path to PKCS#12 certificate for C2PA signing
# Generate self-signed:
#   openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:P-256 \
#     -keyout c2pa-key.pem -out c2pa-cert.pem -days 365 -nodes
#   openssl pkcs12 -export -in c2pa-cert.pem -inkey c2pa-key.pem -out c2pa.p12
C2PA_CERT_PATH=
C2PA_KEY_PATH=
C2PA_CERT_PASSWORD=

# C2PA claim generator identifier
C2PA_CLAIM_GENERATOR=InfinityOS/3.0.0

# ============================================================
# OPENTELEMETRY (optional — leave empty to disable)
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=infinity-os-api